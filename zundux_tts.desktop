[Desktop Entry]
Version=1.0
Type=Application
Name=ZunduxTTS
Comment=VOICEVOX TTS virtual microphone
Exec=sh -c 'if [ -x "$HOME/.local/bin/zundux_tts_launch.sh" ]; then exec "$HOME/.local/bin/zundux_tts_launch.sh"; else exec "$(dirname "$(readlink -f "%k")")/launch.sh"; fi'
Icon=zundux_tts
Terminal=false
StartupWMClass=zundux_tts
Categories=AudioVideo;Audio;
